---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildRelatedClusters,
  categoryLabelFor,
  categoryPathFor,
  entrySlug,
  errorPath,
  findRelatedEntries,
  referenceLinksFor,
} from '../../lib/taxonomy';
import { absoluteUrl, SITE_NAME } from '../../lib/seo';
import { formatPublicDate, getUpdatedTimestamp, sortByUpdatedTimestamp } from '../../lib/dates';
import { buildDataAwareFaqItems } from '../../lib/faq';
import { deriveEvidenceSchema, evidenceStatusDescription, evidenceStatusLabel, stripGeneratedEvidenceAndFaq } from '../../lib/evidence';
import { renderTrustedMarkdown } from '../../lib/markdown';
import { buildErrorCatalog } from '../../lib/error-catalog';

export async function getStaticPaths() {
  const errors = await getCollection('errors');
  const catalog = buildErrorCatalog(errors);

  return catalog.staticEntries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry, staticSlugList: [...catalog.staticSlugs] },
  }));
}

const { entry, staticSlugList } = Astro.props;
const staticSlugs = new Set(staticSlugList);
const allErrors = await getCollection('errors');
const publicCategory = categoryLabelFor(entry);
const evidence = deriveEvidenceSchema(entry);
const articleHtml = renderTrustedMarkdown(stripGeneratedEvidenceAndFaq(entry.body));
const relatedErrors = findRelatedEntries(entry, allErrors, 12, staticSlugs);
const relatedClusters = buildRelatedClusters(entry, allErrors, staticSlugs);
const referenceLinks = referenceLinksFor(entry);
const entryTokens = new Set(
  `${entry.data.error_signature} ${entry.data.title}`
    .toLowerCase()
    .split(/[^a-z0-9]+/)
    .filter((token) => token.length >= 3)
);
const similarSignatureLinks = allErrors
  .filter((candidate) => entrySlug(candidate) !== entrySlug(entry) && staticSlugs.has(entrySlug(candidate)))
  .map((candidate) => {
    const candidateTokens = `${candidate.data.error_signature} ${candidate.data.title}`
      .toLowerCase()
      .split(/[^a-z0-9]+/)
      .filter((token) => token.length >= 3);
    const overlap = candidateTokens.filter((token) => entryTokens.has(token)).length;
    return { candidate, overlap };
  })
  .filter((item) => item.overlap >= 2)
  .sort((a, b) => b.overlap - a.overlap || (sortByUpdatedTimestamp([a.candidate, b.candidate])[0] === b.candidate ? 1 : -1))
  .slice(0, 4)
  .map((item) => item.candidate);
const relatedHubLinks = [
  { label: publicCategory, path: categoryPathFor(publicCategory) },
  { label: entry.data.technology, path: categoryPathFor(publicCategory) },
].filter((hub, index, hubs) => hubs.findIndex((candidate) => candidate.label === hub.label) === index);
const canonical = absoluteUrl(errorPath(entry));
const updatedIso = getUpdatedTimestamp(entry) ?? new Date(0).toISOString();
const publishedIso = entry.data.published_at ? (getUpdatedTimestamp({ data: { updated_at: entry.data.published_at } }) ?? updatedIso) : updatedIso;
const faqItems = buildDataAwareFaqItems(entry, evidence);
const verificationStatus = evidenceStatusLabel(evidence.evidence_status);
const sourceStatusDescription = evidenceStatusDescription(evidence);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: entry.data.title,
    description: entry.data.description,
    mainEntityOfPage: canonical,
    dateModified: updatedIso,
    datePublished: publishedIso,
    about: [entry.data.technology, publicCategory],
    articleSection: publicCategory,
    isBasedOn: evidence.evidence_sources.map((source) => source.source_url),
    author: {
      '@type': 'Organization',
      name: SITE_NAME,
    },
    citation: [...evidence.evidence_sources.map((source) => source.source_url), ...referenceLinks.map((link) => link.url)].filter((url) =>
      url.startsWith('https://')
    ),
  },
  ...(faqItems.length > 0
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqItems.map((item) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.answer,
            },
          })),
        },
      ]
    : []),
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={updatedIso}
  structuredData={structuredData}
>
  <article class="error-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href={categoryPathFor(publicCategory)}>{publicCategory}</a>
      <span aria-hidden="true">/</span>
      <span>{entry.data.title}</span>
    </nav>

    <header class="error-header">
      <p class="eyebrow">{entry.data.technology} / {entry.data.category}</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <div class="badge-row" aria-label="Page evidence status">
        <span class={evidence.source_backed ? 'status-badge status-badge--source' : 'status-badge'}>{verificationStatus}</span>
        <span class="status-badge">Last updated {formatPublicDate(updatedIso)}</span>
        <span class="status-badge">{evidence.source_count} source{evidence.source_count === 1 ? '' : 's'}</span>
        <span class="status-badge">Needs local verification</span>
      </div>
      <dl class="facts">
        <div>
          <dt>Category</dt>
          <dd><a href={categoryPathFor(publicCategory)}>{publicCategory}</a></dd>
        </div>
        <div>
          <dt>Error signature</dt>
          <dd><code>{entry.data.error_signature}</code></dd>
        </div>
        <div>
          <dt>Quick fix</dt>
          <dd>{entry.data.quick_fix}</dd>
        </div>
        <div>
          <dt>Updated</dt>
          <dd><time datetime={updatedIso}>{formatPublicDate(updatedIso)}</time></dd>
        </div>
        <div>
          <dt>Verification status</dt>
          <dd>{verificationStatus}</dd>
        </div>
        <div>
          <dt>Evidence</dt>
          <dd>{evidence.source_count} public source URL{evidence.source_count === 1 ? '' : 's'}</dd>
        </div>
      </dl>
    </header>

    <section class="trust-panel" aria-labelledby="before-changing-heading">
      <h2 id="before-changing-heading">Before you change production</h2>
      <p>{sourceStatusDescription}</p>
      <ul>
        <li>Reproduce the smallest failing action and save non-secret logs before changing configuration.</li>
        <li>Check versions for {entry.data.technology}, related SDKs, package managers, CI runners, and hosting providers.</li>
        <li>Change one setting or dependency at a time, then rerun the same failing command or request.</li>
        <li>Avoid destructive commands, credential rotation, billing changes, or security relaxations without a rollback plan.</li>
      </ul>
    </section>

    <div class="article-body" set:html={articleHtml} />

    <section class="trust-panel" aria-labelledby="diagnostic-flow-heading">
      <h2 id="diagnostic-flow-heading">Diagnostic flow for this page</h2>
      <ol>
        <li>Match <code>{entry.data.error_signature}</code> exactly before applying the quick fix.</li>
        <li>Compare the failing environment with {entry.data.technology} versions, account scope, provider settings, and deployment context.</li>
        <li>Check the listed common causes in order, starting with the cause that best matches your logs.</li>
        <li>Use the evidence status below to decide whether to confirm against public sources or official documentation.</li>
        <li>Apply one reversible change, rerun the smallest failing action, and keep rollback notes.</li>
      </ol>
    </section>

    <aside class="trust-panel" aria-labelledby="evidence-heading">
      <h2 id="evidence-heading">Evidence and references</h2>
      <p>
        This page is labeled <strong>{verificationStatus}</strong>. Use the exact error signature, technology, category,
        and last-updated date above to compare this guide with your local environment before changing production systems.
      </p>
      <dl class="facts">
        <div>
          <dt>Evidence status</dt>
          <dd>{verificationStatus}</dd>
        </div>
        <div>
          <dt>Source count</dt>
          <dd>{evidence.source_count}</dd>
        </div>
        <div>
          <dt>Source domains</dt>
          <dd>{evidence.source_domains.length ? evidence.source_domains.join(', ') : 'No public source URL found in this Markdown record'}</dd>
        </div>
        <div>
          <dt>Last checked</dt>
          <dd>{evidence.last_checked ? formatPublicDate(evidence.last_checked) : 'No dedicated last-checked field; using page update date only'}</dd>
        </div>
      </dl>
      {
        evidence.evidence_sources.length > 0 && (
          <ul>
            {evidence.evidence_sources.map((source) => (
              <li>
                <a href={source.source_url} target="_blank" rel="noopener noreferrer">
                  {source.source_label}
                </a>
                <span> ({source.source_type.replace(/_/g, ' ')})</span>
              </li>
            ))}
          </ul>
        )
      }
      <h3>General references</h3>
      <ul>
        {referenceLinks.map((link) => (
          <li>
            <a href={link.url} target={link.url.startsWith('http') ? '_blank' : undefined} rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.label}</a>
          </li>
        ))}
      </ul>
    </aside>

    <aside class="trust-panel" aria-labelledby="when-to-avoid-heading">
      <h2 id="when-to-avoid-heading">When to avoid this fix</h2>
      <p>
        Pause before applying the quick fix if the error signature does not match, the source references describe a
        different version, the change would expose secrets, or the fix requires production infrastructure changes without
        a tested rollback path.
      </p>
    </aside>

    {
      relatedErrors.length > 0 && (
        <aside class="related" aria-labelledby="related-heading">
          <h2 id="related-heading">Related error pages</h2>
          <ul>
            {relatedErrors.map((related) => (
              <li>
                <a href={errorPath(related)}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
    {
      relatedClusters.length > 0 && (
        <aside class="related" aria-labelledby="deep-related-heading">
          <h2 id="deep-related-heading">More related fixes</h2>
          <div class="related-grid">
            {relatedClusters.map((cluster) => (
              <section>
                <h3>{cluster.heading}</h3>
                <ul>
                  {cluster.entries.map((related) => (
                    <li>
                      <a href={errorPath(related)}>{related.data.title}</a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </aside>
      )
    }
    {
      similarSignatureLinks.length > 0 && (
        <aside class="related" aria-labelledby="similar-signature-heading">
          <h2 id="similar-signature-heading">Similar error signatures</h2>
          <ul>
            {similarSignatureLinks.map((related) => (
              <li>
                <a href={errorPath(related)}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
    {
      relatedHubLinks.length > 0 && (
        <aside class="related" aria-labelledby="related-hubs-heading">
          <h2 id="related-hubs-heading">Related troubleshooting hubs</h2>
          <ul>
            {relatedHubLinks.map((hub) => (
              <li>
                <a href={hub.path}>{hub.label}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
    <aside class="trust-panel" aria-labelledby="faq-heading">
      <h2 id="faq-heading">FAQ</h2>
      {faqItems.map((item) => (
        <section>
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </section>
      ))}
    </aside>
  </article>
</BaseLayout>
