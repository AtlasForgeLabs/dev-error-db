---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const errors = await getCollection('errors');

  return errors.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const entrySlug = entry.id.replace(/\.mdx?$/, '');
const { Content } = await render(entry);
const relatedErrors = (await getCollection('errors'))
  .filter((candidate) => candidate.id.replace(/\.mdx?$/, '') !== entrySlug)
  .filter(
    (candidate) =>
      candidate.data.technology === entry.data.technology ||
      candidate.data.category === entry.data.category
  )
  .slice(0, 4);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="error-page">
    <header class="error-header">
      <p class="eyebrow">{entry.data.technology} / {entry.data.category}</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <dl class="facts">
        <div>
          <dt>Error signature</dt>
          <dd><code>{entry.data.error_signature}</code></dd>
        </div>
        <div>
          <dt>Quick fix</dt>
          <dd>{entry.data.quick_fix}</dd>
        </div>
        <div>
          <dt>Updated</dt>
          <dd><time datetime={entry.data.updated}>{entry.data.updated}</time></dd>
        </div>
      </dl>
    </header>

    <Content />

    {
      relatedErrors.length > 0 && (
        <aside class="related" aria-labelledby="related-heading">
          <h2 id="related-heading">Related error pages</h2>
          <ul>
            {relatedErrors.map((related) => (
              <li>
                <a href={`/errors/${related.id.replace(/\.mdx?$/, '')}/`}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>
