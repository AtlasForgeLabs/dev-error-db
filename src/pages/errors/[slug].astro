---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildRelatedClusters,
  categoryLabelFor,
  categoryPathFor,
  entrySlug,
  errorPath,
  findRelatedEntries,
  referenceLinksFor,
} from '../../lib/taxonomy';
import { absoluteUrl, SITE_NAME } from '../../lib/seo';
import { formatPublicDate, getUpdatedTimestamp, sortByUpdatedTimestamp } from '../../lib/dates';

function extractFaqItems(markdownBody: string) {
  const faqStart = markdownBody.indexOf('\n## FAQ');

  if (faqStart === -1) {
    return [];
  }

  const faqSection = markdownBody.slice(faqStart);
  const blocks = faqSection.split('\n### ').slice(1);

  return blocks
    .map((block) => {
      const [questionLine, ...answerLines] = block.split('\n');
      const answer = answerLines
        .join(' ')
        .replace(/`/g, '')
        .replace(/\[(.*?)\]\((.*?)\)/g, '$1')
        .replace(/\s+/g, ' ')
        .trim();

      return {
        question: questionLine.trim(),
        answer,
      };
    })
    .filter((item) => item.question.length > 0 && item.answer.length > 0)
    .slice(0, 6);
}

function extractSourceUrls(markdownBody: string) {
  return [...markdownBody.matchAll(/https?:\/\/[^\s)\]]+/g)]
    .map((match) => match[0].replace(/[.,]+$/, ''))
    .filter((url, index, urls) => urls.indexOf(url) === index);
}

export async function getStaticPaths() {
  const errors = await getCollection('errors');

  return errors.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const allErrors = await getCollection('errors');
const publicCategory = categoryLabelFor(entry);
const { Content } = await render(entry);
const relatedErrors = findRelatedEntries(entry, allErrors);
const relatedClusters = buildRelatedClusters(entry, allErrors);
const referenceLinks = referenceLinksFor(entry);
const sameCategoryLinks = allErrors
  .filter((candidate) => entrySlug(candidate) !== entrySlug(entry) && categoryLabelFor(candidate) === publicCategory)
  .slice(0, 0);
const entryTokens = new Set(
  `${entry.data.error_signature} ${entry.data.title}`
    .toLowerCase()
    .split(/[^a-z0-9]+/)
    .filter((token) => token.length >= 3)
);
const similarSignatureLinks = allErrors
  .filter((candidate) => entrySlug(candidate) !== entrySlug(entry))
  .map((candidate) => {
    const candidateTokens = `${candidate.data.error_signature} ${candidate.data.title}`
      .toLowerCase()
      .split(/[^a-z0-9]+/)
      .filter((token) => token.length >= 3);
    const overlap = candidateTokens.filter((token) => entryTokens.has(token)).length;
    return { candidate, overlap };
  })
  .filter((item) => item.overlap >= 2)
  .sort((a, b) => b.overlap - a.overlap || (sortByUpdatedTimestamp([a.candidate, b.candidate])[0] === b.candidate ? 1 : -1))
  .slice(0, 0)
  .map((item) => item.candidate);
const canonical = absoluteUrl(errorPath(entry));
const updatedIso = getUpdatedTimestamp(entry) ?? new Date(0).toISOString();
const publishedIso = entry.data.published_at ? (getUpdatedTimestamp({ data: { updated_at: entry.data.published_at } }) ?? updatedIso) : updatedIso;
const faqItems = extractFaqItems(entry.body);
const sourceUrls = extractSourceUrls(entry.body);
const hasSourceEvidence = sourceUrls.length > 0;
const verificationStatus = hasSourceEvidence ? 'Source-backed' : 'General troubleshooting guidance';
const sourceStatusDescription = hasSourceEvidence
  ? 'This page includes public source URLs in the imported troubleshooting record. Verify that the source still matches your version and environment.'
  : 'This page does not expose source URLs in the page body. Treat it as general guidance and verify against official documentation before changing systems.';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: entry.data.title,
    description: entry.data.description,
    mainEntityOfPage: canonical,
    dateModified: updatedIso,
    datePublished: publishedIso,
    about: [entry.data.technology, publicCategory],
    articleSection: publicCategory,
    author: {
      '@type': 'Organization',
      name: SITE_NAME,
    },
    citation: referenceLinks.map((link) => link.url).filter((url) => url.startsWith('https://')),
  },
  ...(faqItems.length > 0
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqItems.map((item) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.answer,
            },
          })),
        },
      ]
    : []),
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={updatedIso}
  structuredData={structuredData}
>
  <article class="error-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href={categoryPathFor(publicCategory)}>{publicCategory}</a>
      <span aria-hidden="true">/</span>
      <span>{entry.data.title}</span>
    </nav>

    <header class="error-header">
      <p class="eyebrow">{entry.data.technology} / {entry.data.category}</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <div class="badge-row" aria-label="Page evidence status">
        <span class={hasSourceEvidence ? 'status-badge status-badge--source' : 'status-badge'}>{verificationStatus}</span>
        <span class="status-badge">Last updated {formatPublicDate(updatedIso)}</span>
        <span class="status-badge">Needs local verification</span>
      </div>
      <dl class="facts">
        <div>
          <dt>Category</dt>
          <dd><a href={categoryPathFor(publicCategory)}>{publicCategory}</a></dd>
        </div>
        <div>
          <dt>Error signature</dt>
          <dd><code>{entry.data.error_signature}</code></dd>
        </div>
        <div>
          <dt>Quick fix</dt>
          <dd>{entry.data.quick_fix}</dd>
        </div>
        <div>
          <dt>Updated</dt>
          <dd><time datetime={updatedIso}>{formatPublicDate(updatedIso)}</time></dd>
        </div>
        <div>
          <dt>Verification status</dt>
          <dd>{verificationStatus}</dd>
        </div>
      </dl>
    </header>

    <section class="trust-panel" aria-labelledby="before-changing-heading">
      <h2 id="before-changing-heading">Before you change production</h2>
      <p>{sourceStatusDescription}</p>
      <ul>
        <li>Reproduce the smallest failing action and save non-secret logs before changing configuration.</li>
        <li>Check versions for {entry.data.technology}, related SDKs, package managers, CI runners, and hosting providers.</li>
        <li>Change one setting or dependency at a time, then rerun the same failing command or request.</li>
        <li>Avoid destructive commands, credential rotation, billing changes, or security relaxations without a rollback plan.</li>
      </ul>
    </section>

    <Content />

    <aside class="trust-panel" aria-labelledby="evidence-heading">
      <h2 id="evidence-heading">Evidence and references</h2>
      <p>
        This page is labeled <strong>{verificationStatus}</strong>. Use the exact error signature, technology, category,
        and last-updated date above to compare this guide with your local environment before changing production systems.
      </p>
      {hasSourceEvidence && <p>Imported source URLs found on this page: {sourceUrls.length}</p>}
      <ul>
        {referenceLinks.map((link) => (
          <li>
            <a href={link.url} target={link.url.startsWith('http') ? '_blank' : undefined} rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.label}</a>
          </li>
        ))}
      </ul>
    </aside>

    <aside class="trust-panel" aria-labelledby="when-to-avoid-heading">
      <h2 id="when-to-avoid-heading">When to avoid this fix</h2>
      <p>
        Pause before applying the quick fix if the error signature does not match, the source references describe a
        different version, the change would expose secrets, or the fix requires production infrastructure changes without
        a tested rollback path.
      </p>
    </aside>

    {
      relatedErrors.length > 0 && (
        <aside class="related" aria-labelledby="related-heading">
          <h2 id="related-heading">Related troubleshooting pages</h2>
          <ul>
            {relatedErrors.map((related) => (
              <li>
                <a href={errorPath(related)}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
    {
      relatedClusters.length > 0 && (
        <aside class="related" aria-labelledby="deep-related-heading">
          <h2 id="deep-related-heading">More related fixes</h2>
          <div class="related-grid">
            {relatedClusters.map((cluster) => (
              <section>
                <h3>{cluster.heading}</h3>
                <ul>
                  {cluster.entries.map((related) => (
                    <li>
                      <a href={errorPath(related)}>{related.data.title}</a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </aside>
      )
    }
    {
      sameCategoryLinks.length > 0 && (
        <aside class="related" aria-labelledby="same-category-heading">
          <h2 id="same-category-heading">More in {publicCategory}</h2>
          <ul>
            {sameCategoryLinks.map((related) => (
              <li>
                <a href={errorPath(related)}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
    {
      similarSignatureLinks.length > 0 && (
        <aside class="related" aria-labelledby="similar-signature-heading">
          <h2 id="similar-signature-heading">Similar error signatures</h2>
          <ul>
            {similarSignatureLinks.map((related) => (
              <li>
                <a href={errorPath(related)}>{related.data.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>
