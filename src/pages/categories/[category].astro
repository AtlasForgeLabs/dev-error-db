---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  DEFAULT_PAGE_SIZE,
  categoryPathFor,
  entrySlug,
  getCategoryGroups,
  getEntriesBySearchSignals,
  getRelatedCategoryGroups,
  getTrendingEntries,
  paginateEntries,
  revenueHubProfileFor,
  sortEntriesByUpdated,
} from '../../lib/taxonomy';
import { formatPublicDate, getUpdatedTimestamp, sortByUpdatedTimestamp } from '../../lib/dates';
import { SITE_URL } from '../../lib/seo';
import { deriveEvidenceSchema } from '../../lib/evidence';

function countBy(values: string[]) {
  const counts = new Map<string, number>();

  for (const value of values) {
    counts.set(value, (counts.get(value) ?? 0) + 1);
  }

  return [...counts.entries()].sort((a, b) => b[1] - a[1]);
}

export async function getStaticPaths() {
  const errors = await getCollection('errors');
  const groups = getCategoryGroups(errors);

  return groups.map((group) => ({
    params: { category: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
const pageTitle = `${group.label} error troubleshooting cluster`;
const pageDescription = `${group.entries.length} ${group.label} error troubleshooting page${
  group.entries.length === 1 ? '' : 's'
} with concise explanations, common causes, quick fixes, and related developer errors.`;
const allGroups = getCategoryGroups(await getCollection('errors'));
const hubProfile = revenueHubProfileFor(group.label);
const technologyCounts = countBy(group.entries.map((entry) => entry.data.technology));
const sortedEntries = sortEntriesByUpdated(group.entries);
const latestEntries = sortedEntries.slice(0, 6);
const entriesWithEvidence = sortedEntries.map((entry) => ({ entry, evidence: deriveEvidenceSchema(entry) }));
const allSourceBackedEntries = entriesWithEvidence.filter((item) => item.evidence.source_backed).map((item) => item.entry);
const partialSourceEntries = entriesWithEvidence.filter((item) => item.evidence.evidence_status === 'partial_source').map((item) => item.entry);
const sourceBackedEntries = allSourceBackedEntries.slice(0, 6);
const popularEntries = getTrendingEntries(group.entries, 6);
const topFixes = getEntriesBySearchSignals(group.entries, ['how to fix', 'failed', 'permission denied', 'timeout', 'quota', 'rate limit', 'not found'], 8);
const pagination = paginateEntries(sortedEntries, 1, DEFAULT_PAGE_SIZE);
const relatedCategories = getRelatedCategoryGroups(group, allGroups, 5);
const oldestDate = sortByUpdatedTimestamp(sortedEntries).at(-1);
const newestDate = latestEntries[0];
const commonCauses = countBy(group.entries.flatMap((entry) => entry.data.common_causes)).slice(0, 6);
const commonErrorTypes = hubProfile?.commonErrorTypes ?? commonCauses.map(([cause]) => cause).slice(0, 6);
const troubleshootingClusters =
  hubProfile?.troubleshootingClusters ??
  [
    'Authentication errors',
    'Timeout and connection errors',
    'Permission errors',
    'Build and deployment errors',
    'Configuration errors',
    'Runtime failures',
  ];
const relatedHubCategories = hubProfile?.relatedCategories
  .map((label) => allGroups.find((candidate) => candidate.label === label))
  .filter((candidate): candidate is (typeof allGroups)[number] => Boolean(candidate))
  .slice(0, 6);
const displayedRelatedCategories = relatedHubCategories?.length ? relatedHubCategories : relatedCategories;
const highIntentTopics = [
  `how to fix ${group.label} errors`,
  `${group.label} error fix`,
  `${group.label} troubleshooting`,
  `${group.label} authentication failed`,
  `${group.label} timeout`,
  `${group.label} permission denied`,
  `${group.label} deployment failed`,
].filter((topic, index, topics) => topics.indexOf(topic) === index);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: pageTitle,
    description: pageDescription,
    url: `${SITE_URL}${categoryPathFor(group.label)}`,
    isPartOf: {
      '@type': 'WebSite',
      name: 'Dev Error DB',
      url: SITE_URL,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${group.label} troubleshooting pages`,
    itemListElement: sortedEntries.slice(0, 30).map((entry, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: entry.data.title,
      url: `${SITE_URL}/errors/${entrySlug(entry)}/`,
    })),
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <section class="category-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>{group.label}</span>
    </nav>

    <p class="eyebrow">Error category</p>
    <h1>{hubProfile?.h1 ?? `${group.label} Errors and Fixes`}</h1>
    <p>{hubProfile?.intro ?? group.description}</p>
    <p>
      This {group.label} troubleshooting hub collects real error signatures, quick fixes, common causes, and
      step-by-step debugging paths for developers who need a practical answer instead of a broad overview.
    </p>
    <p class="count-line">{group.entries.length} article{group.entries.length === 1 ? '' : 's'} in this category.</p>
    <ul class="stats-list">
      <li><strong>Technologies covered:</strong> {technologyCounts.length}</li>
      <li><strong>Date range:</strong> {oldestDate ? formatPublicDate(getUpdatedTimestamp(oldestDate)) : 'n/a'} to {newestDate ? formatPublicDate(getUpdatedTimestamp(newestDate)) : 'n/a'}</li>
      <li><strong>Latest updates:</strong> {latestEntries.length}</li>
      <li><strong>Source-backed pages:</strong> {allSourceBackedEntries.length}</li>
      <li><strong>Partial-source pages:</strong> {partialSourceEntries.length}</li>
    </ul>

    <section class="latest-pages" aria-labelledby="overview-heading">
      <h2 id="overview-heading">Troubleshooting overview</h2>
      <p>
        Start by matching the exact error message, then check the technology, environment, credentials, network path,
        and deployment context. The pages below are grouped so you can move from broad {group.label} symptoms to
        specific root-cause families without relying on client-side search.
      </p>
      <p>
        Evidence labels are derived at build time from each Markdown record. Source-backed entries have public URLs under
        a Sources checked section, while partial-source entries expose public links without a complete source block.
      </p>
    </section>

    <section class="latest-pages" aria-labelledby="diagnostic-workflow-heading">
      <h2 id="diagnostic-workflow-heading">{group.label} diagnostic workflow</h2>
      <ol>
        <li>Copy the exact error signature and compare it with the page title, code block, and technology label.</li>
        <li>Check whether the failure is local, CI-only, deployment-only, provider-side, or account-specific.</li>
        <li>Collect non-secret versions, configuration names, request IDs, and timestamps before making changes.</li>
        <li>Review source-backed or partial-source pages first when the issue might depend on provider behavior or version-specific bugs.</li>
        <li>Apply the smallest reversible fix and rerun the same failing action.</li>
      </ol>
    </section>

    <section class="latest-pages" aria-labelledby="common-error-types-heading">
      <h2 id="common-error-types-heading">Common error types</h2>
      <ul>
        {commonErrorTypes.map((errorType) => (
          <li>{errorType}</li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="common-causes-heading">
      <h2 id="common-causes-heading">Common causes</h2>
      <ul>
        {commonCauses.map(([cause, count]) => (
          <li>{cause} ({count} page{count === 1 ? '' : 's'})</li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="technology-heading">
      <h2 id="technology-heading">Related technologies</h2>
      <ul>
        {
          (hubProfile?.relatedTechnologies ?? technologyCounts.map(([technology]) => technology).slice(0, 8)).map((technology) => {
            const count = technologyCounts.find(([candidate]) => candidate === technology)?.[1];
            return <li>{technology}{count ? ` (${count} page${count === 1 ? '' : 's'})` : ''}</li>;
          })
        }
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="clusters-heading">
      <h2 id="clusters-heading">Troubleshooting clusters</h2>
      <ul>
        {troubleshootingClusters.map((cluster) => (
          <li>{cluster}</li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="latest-pages-heading">
      <h2 id="latest-pages-heading">Latest pages in this category</h2>
      <ul>
        {latestEntries.map((entry) => (
          <li>
            <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
            <span> ({formatPublicDate(getUpdatedTimestamp(entry))})</span>
          </li>
        ))}
      </ul>
    </section>

    {
      sourceBackedEntries.length > 0 && (
        <section class="latest-pages" aria-labelledby="source-backed-pages-heading">
          <h2 id="source-backed-pages-heading">Representative source-backed errors</h2>
          <p>
            These entries include public source URLs in the imported page body. Use them first when you need evidence
            for provider behavior, SDK regressions, or version-specific failures.
          </p>
          <ul>
            {sourceBackedEntries.map((entry) => (
              <li>
                <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
                <span> ({formatPublicDate(getUpdatedTimestamp(entry))})</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="latest-pages" aria-labelledby="safe-debugging-heading">
      <h2 id="safe-debugging-heading">Safe debugging checklist</h2>
      <ul>
        <li>Do not paste API keys, tokens, cookies, private repository snippets, or customer data into public issues.</li>
        <li>Keep a rollback path before changing credentials, billing limits, DNS, CI secrets, or production deploy settings.</li>
        <li>Prefer official documentation and source-backed entries over broad guesses when the error affects paid APIs or production deploys.</li>
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="popular-pages-heading">
      <h2 id="popular-pages-heading">Trending errors</h2>
      <ul>
        {popularEntries.map((entry) => (
          <li>
            <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="top-fixes-heading">
      <h2 id="top-fixes-heading">Top fixes</h2>
      <ul>
        {topFixes.map((entry) => (
          <li>
            <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="intent-topics-heading">
      <h2 id="intent-topics-heading">High-intent troubleshooting topics</h2>
      <ul>
        {highIntentTopics.map((topic) => (
          <li>{topic}</li>
        ))}
      </ul>
    </section>

    <section class="latest-pages" aria-labelledby="related-categories-heading">
      <h2 id="related-categories-heading">Related categories</h2>
      <ul>
        {displayedRelatedCategories.map((relatedGroup) => (
          <li>
            <a href={`/categories/${relatedGroup.slug}/`}>{relatedGroup.label}</a> ({relatedGroup.entries.length})
          </li>
        ))}
      </ul>
    </section>

    <div class="cards">
      {
        pagination.pageItems.map((entry) => (
          <article class="card">
            <div class="meta-row">
              <span>{entry.data.category}</span>
              <span>{entry.data.technology}</span>
            </div>
            <h2>
              <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
            </h2>
            <p>{entry.data.description}</p>
            <code>{entry.data.error_signature}</code>
          </article>
        ))
      }
    </div>
    {
      pagination.totalPages > 1 && (
        <nav class="pagination" aria-label="Category pagination">
          <a href={`/categories/${group.slug}/`} aria-current="page">
            1
          </a>
          {Array.from({ length: Math.min(5, pagination.totalPages - 1) }, (_, index) => {
            const page = index + 2;
            return <a href={`/categories/${group.slug}/page/${page}/`}>{page}</a>;
          })}
          {pagination.totalPages > 6 && <span>...</span>}
          {pagination.totalPages > 6 && <a href={`/categories/${group.slug}/page/${pagination.totalPages}/`}>{pagination.totalPages}</a>}
        </nav>
      )
    }

    <section class="latest-pages hub-cta" aria-labelledby="hub-cta-heading">
      <h2 id="hub-cta-heading">Browse all {group.label} troubleshooting pages</h2>
      <p>
        Continue through the full static archive for this hub. Every listed page is crawlable and keeps its existing
        canonical URL.
      </p>
      <p><a class="button" href={categoryPathFor(group.label)}>Browse all {group.label} troubleshooting pages</a></p>
    </section>
  </section>
</BaseLayout>
