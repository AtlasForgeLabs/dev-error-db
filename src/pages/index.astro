---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  categoryPathFor,
  entrySlug,
  getEntriesByCategories,
  getEntriesBySearchSignals,
  getCategoryGroups,
  getExistingRevenueHubLinks,
  getTrendingEntries,
  sortEntriesByUpdated,
} from '../lib/taxonomy';
import { formatPublicDate, getUpdatedTimestamp } from '../lib/dates';
import { SITE_URL } from '../lib/seo';

const errors = await getCollection('errors');
const categoryGroups = getCategoryGroups(errors);
const sortedByUpdated = sortEntriesByUpdated(errors);
const latestPages = sortedByUpdated.slice(0, 20);
const recentlyUpdatedPages = sortedByUpdated.slice(0, 10);
const trendingPages = getTrendingEntries(errors, 12);
const mostSearchedFixes = getEntriesBySearchSignals(errors, ['how to fix', 'failed', 'not found', 'permission denied', 'timeout', 'quota', 'rate limit'], 12);
const apiFailures = getEntriesByCategories(errors, ['OpenAI API', 'Anthropic API', 'LiteLLM', 'Ollama'], 10);
const deploymentFailures = getEntriesByCategories(errors, ['Deployment', 'GitHub Actions', 'Cloud Platforms', 'Cloudflare'], 10);
const aiCodingErrors = getEntriesByCategories(errors, ['AI Coding Tools', 'GitHub Copilot', 'Cursor'], 10);
const topCategories = [...categoryGroups].sort((a, b) => b.entries.length - a.entries.length).slice(0, 12);
const revenueHubLinks = getExistingRevenueHubLinks(categoryGroups);
const totalCategories = categoryGroups.length;
const totalErrors = errors.length;
const totalTechnologies = new Set(errors.map((entry) => entry.data.technology)).size;
const sourceBackedErrors = errors.filter((entry) => /https?:\/\//.test(entry.body)).length;
const recentlyUpdatedSourceBacked = sortedByUpdated.filter((entry) => /https?:\/\//.test(entry.body)).slice(0, 8);
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Dev Error DB',
    url: SITE_URL,
    description:
      'Static troubleshooting hub for developer error messages, API failures, Docker issues, deployment errors, npm failures, Python errors, AI coding tools, and GitHub Actions.',
    potentialAction: {
      '@type': 'SearchAction',
      target: `${SITE_URL}/errors/?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'High-value developer troubleshooting hubs',
    itemListElement: revenueHubLinks.map((hub, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: hub.label,
      url: `${SITE_URL}${hub.path}`,
    })),
  },
];
---

<BaseLayout
  title="Dev Error DB"
  description="Find practical fixes for developer error messages across API errors, deployment failures, Docker, npm, Python, AI coding tools, and GitHub Actions."
  structuredData={structuredData}
>
  <section class="hero hero--compact">
    <p class="eyebrow">Developer troubleshooting hub</p>
    <h1>Developer troubleshooting database and error fix guide</h1>
    <p>
      Match exact error signatures, read source-backed troubleshooting notes where available, and move from symptoms to
      safe checks for API errors, deployment failures, Docker, npm, Python, AI coding tools, and GitHub Actions.
    </p>
  </section>

  <section class="stats-strip" aria-label="Site statistics">
    <article>
      <h2>{totalErrors}</h2>
      <p>Error pages</p>
    </article>
    <article>
      <h2>{totalCategories}</h2>
      <p>Topic clusters</p>
    </article>
    <article>
      <h2>{totalTechnologies}</h2>
      <p>Technologies covered</p>
    </article>
    <article>
      <h2>{sourceBackedErrors}</h2>
      <p>Pages with public source URLs</p>
    </article>
  </section>

  <section class="intent-grid" aria-labelledby="why-developers-heading">
    <h2 id="why-developers-heading">How to use Dev Error DB</h2>
    <div class="feature-grid">
      <article>
        <h3>Match the exact signature</h3>
        <p>Search or browse for the exact message first. Similar wording can point to a different provider, SDK, or runtime path.</p>
      </article>
      <article>
        <h3>Check evidence and scope</h3>
        <p>Use source-backed labels, technology, category, and update dates to decide whether the page matches your environment.</p>
      </article>
      <article>
        <h3>Apply one safe change</h3>
        <p>Collect non-secret diagnostics, change one variable at a time, and keep a rollback path before touching production.</p>
      </article>
    </div>
  </section>

  <section class="search-entry" aria-labelledby="search-entry-heading">
    <h2 id="search-entry-heading">Find an error</h2>
    <form action="/errors/" method="get">
      <label for="homepage-error-search">Error message, tool, provider, or technology</label>
      <div>
        <input id="homepage-error-search" name="q" type="search" placeholder="429 rate limit, module not found, function timeout" />
        <button type="submit">Search</button>
      </div>
    </form>
    <p>
      Search is static-friendly and falls back to the crawlable error archive. Use quotes from the exact error when possible.
    </p>
  </section>

  <section class="filters" aria-labelledby="top-categories-heading">
    <h2 id="top-categories-heading">Popular troubleshooting topics</h2>
    <p>
      Browse common developer error categories including API errors, deployment failures, Docker issues, AI coding tools,
      cloud platform problems, npm, Python, GitHub Actions, SSL, Git, and DNS.
    </p>
    <div class="category-grid">
      {
        topCategories.map((group) => (
          <a class="category-card" href={categoryPathFor(group.label)}>
            <strong>{group.label}</strong>
            <span>{group.entries.length} error{group.entries.length === 1 ? '' : 's'}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="filters" aria-labelledby="revenue-hubs-heading">
    <h2 id="revenue-hubs-heading">High-value troubleshooting hubs</h2>
    <p>
      Start with the strongest revenue-focused hubs for API failures, AI coding assistant problems, CI/CD breakage,
      Docker issues, deployment failures, Cloudflare errors, LiteLLM routing, and Ollama model runtime errors.
    </p>
    <div class="category-grid">
      {
        revenueHubLinks.map((hub) => (
          <a class="category-card category-card--hub" href={hub.path}>
            <strong>{hub.label}</strong>
            <span>{hub.count} fix{hub.count === 1 ? '' : 'es'}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="link-columns" aria-labelledby="source-backed-heading">
    <h2 id="source-backed-heading">Recently updated source-backed errors</h2>
    <p>
      These pages include public source URLs in the imported page body. They still require local verification, but they
      are stronger starting points than generic checklists.
    </p>
    <ul>
      {
        recentlyUpdatedSourceBacked.map((entry) => (
          <li>
            <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a> ({formatPublicDate(getUpdatedTimestamp(entry))})
          </li>
        ))
      }
    </ul>
  </section>

  <section class="intent-grid" aria-labelledby="methodology-heading">
    <h2 id="methodology-heading">How we build troubleshooting guidance</h2>
    <div class="feature-grid">
      <article>
        <h3>Structured inputs</h3>
        <p>Pages should start from a real error signature, category, technology, common causes, and update fields.</p>
      </article>
      <article>
        <h3>Source labels</h3>
        <p>When a record includes public references, the page labels that evidence instead of hiding it in a generic template.</p>
      </article>
      <article>
        <h3>Correction path</h3>
        <p>Outdated or unsupported claims can be reported through the contact page with the page URL and public source.</p>
      </article>
    </div>
    <p>
      Read the <a href="/editorial-methodology/">editorial methodology</a>,
      <a href="/source-policy/">source policy</a>, and
      <a href="/troubleshooting-methodology/">troubleshooting methodology</a>.
    </p>
  </section>

  <section class="latest-pages" aria-labelledby="before-fix-heading">
    <h2 id="before-fix-heading">What to check before applying a fix</h2>
    <ul>
      <li>Confirm the exact error signature and the smallest command, request, CI job, or editor action that reproduces it.</li>
      <li>Record versions for the runtime, package manager, SDK, CLI, provider, operating system, and deployment target.</li>
      <li>Redact secrets before sharing logs, issue links, screenshots, stack traces, or request payloads.</li>
      <li>Test one change at a time in local or staging before applying it to production.</li>
    </ul>
  </section>

  <section class="topic-nav" aria-labelledby="topic-nav-heading">
    <h2 id="topic-nav-heading">Common error categories</h2>
    <p>Use these crawlable category hubs to move from a broad failure mode to specific error signatures and fixes.</p>
    <div class="tag-list">
      {categoryGroups.map((group) => <a href={categoryPathFor(group.label)}>{group.label}</a>)}
    </div>
  </section>

  <section id="trending" class="error-list" aria-labelledby="trending-heading">
    <h2 id="trending-heading">Recently trending developer errors</h2>
    <div class="cards">
      {
        trendingPages.map((entry) => (
          <article class="card">
            <div class="meta-row">
              <span>{entry.data.technology}</span>
              <span>{entry.data.category}</span>
              <span>Updated {formatPublicDate(getUpdatedTimestamp(entry))}</span>
            </div>
            <h3>
              <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
            </h3>
            <p>{entry.data.description}</p>
            <code>{entry.data.error_signature}</code>
          </article>
        ))
      }
    </div>
  </section>

  <section class="link-columns" aria-labelledby="most-searched-heading">
    <h2 id="most-searched-heading">Most searched fixes</h2>
    <ul>
      {mostSearchedFixes.map((entry) => <li><a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a></li>)}
    </ul>
    <p><a href="/trending/">Browse the trending troubleshooting archive</a></p>
  </section>

  <section class="link-columns" aria-labelledby="api-failures-heading">
    <h2 id="api-failures-heading">Common API failures</h2>
    <p>Authentication failed, rate limit, quota exceeded, model not found, context length, timeout, and provider routing errors.</p>
    <ul>
      {apiFailures.map((entry) => <li><a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a></li>)}
    </ul>
  </section>

  <section class="link-columns" aria-labelledby="deployment-heading">
    <h2 id="deployment-heading">Deployment troubleshooting</h2>
    <p>Vercel build failed, GitHub Actions failed, permission denied, missing modules, SSL handshake, DNS, and cloud origin failures.</p>
    <ul>
      {deploymentFailures.map((entry) => <li><a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a></li>)}
    </ul>
  </section>

  <section class="link-columns" aria-labelledby="ai-coding-heading">
    <h2 id="ai-coding-heading">AI coding assistant errors</h2>
    <p>Claude Code, Cursor, GitHub Copilot, OpenRouter, Ollama, LiteLLM, and model-routing failures in coding workflows.</p>
    <ul>
      {aiCodingErrors.map((entry) => <li><a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a></li>)}
    </ul>
  </section>

  <section class="error-list" aria-labelledby="latest-value-heading">
    <h2 id="latest-value-heading">Latest high-value pages</h2>
    <div class="cards">
      {
        latestPages.map((entry) => (
          <article class="card">
            <div class="meta-row">
              <span>{entry.data.technology}</span>
              <span>{entry.data.category}</span>
              <span>Updated {formatPublicDate(getUpdatedTimestamp(entry))}</span>
            </div>
            <h3>
              <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
            </h3>
            <p>{entry.data.description}</p>
            <code>{entry.data.error_signature}</code>
          </article>
        ))
      }
    </div>
    <p><a href="/errors/">Browse all error pages with pagination</a> or <a href="/latest/">open the latest troubleshooting archive</a>.</p>
  </section>

  <section class="error-list" aria-labelledby="recently-updated-heading">
    <h2 id="recently-updated-heading">Recently updated pages</h2>
    <ul>
      {recentlyUpdatedPages.map((entry) => <li><a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a> ({formatPublicDate(getUpdatedTimestamp(entry))})</li>)}
    </ul>
  </section>
</BaseLayout>
