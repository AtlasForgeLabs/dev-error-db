---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categoryPathFor, getCategoryGroups, entrySlug } from '../lib/taxonomy';

const errors = (await getCollection('errors')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const categoryGroups = getCategoryGroups(errors);
---

<BaseLayout
  title="Dev Error DB"
  description="Search concise troubleshooting pages for common developer error messages across npm, Docker, Python, Git, APIs, and more."
>
  <section class="hero">
    <p class="eyebrow">Static developer troubleshooting database</p>
    <h1>Fix developer error messages faster.</h1>
    <p>
      Dev Error DB is a searchable, static-first knowledge base for common build,
      package, runtime, API, and deployment errors.
    </p>
  </section>

  <section class="filters" aria-labelledby="browse-heading">
    <h2 id="browse-heading">Browse by category</h2>
    <div class="category-grid">
      {
        categoryGroups.map((group) => (
          <a class="category-card" href={categoryPathFor(group.label)}>
            <strong>{group.label}</strong>
            <span>{group.entries.length} error{group.entries.length === 1 ? '' : 's'}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section id="errors" class="error-list" aria-labelledby="errors-heading">
    <h2 id="errors-heading">Error pages</h2>
    <div class="cards">
      {
        errors.map((entry) => (
          <article class="card">
            <div class="meta-row">
              <span>{entry.data.technology}</span>
              <span>{entry.data.category}</span>
            </div>
            <h3>
              <a href={`/errors/${entrySlug(entry)}/`}>{entry.data.title}</a>
            </h3>
            <p>{entry.data.description}</p>
            <code>{entry.data.error_signature}</code>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
