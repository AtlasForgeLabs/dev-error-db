---
import '../styles/global.css';
import {
  GA4_MEASUREMENT_ID,
  GA4_SCRIPT_SRC,
  analyticsConfig,
} from '../lib/analytics';
import {
  ADSENSE_CLIENT_ID,
  ADSENSE_SCRIPT_SRC,
  monetizationConfig,
} from '../lib/monetization';
import {
  DEFAULT_OG_IMAGE,
  SITE_NAME,
  SITE_URL,
  absoluteUrl,
  buildMetaDescription,
  buildSeoTitle,
  ensureCanonicalUrl,
} from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  publishedTime?: string;
  modifiedTime?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, publishedTime, modifiedTime, ogType = 'website', structuredData } = Astro.props;
const siteUrl = Astro.site?.toString() ?? SITE_URL;
const canonicalUrl = ensureCanonicalUrl(Astro.url.pathname, canonical, siteUrl);
const pageTitle = buildSeoTitle(title);
const metaDescription = buildMetaDescription(description);
const ogImageUrl = absoluteUrl(DEFAULT_OG_IMAGE, siteUrl);
const structuredDataList = (Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []).filter(
  Boolean
);
const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&family=Sora:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="google-site-verification" content="xrCmk8sMkiAERs-Kt--HK5plyvfDTqAJhUV9ZhW3kVY" />
    {monetizationConfig.auto_ads_enabled && <meta name="google-adsense-account" content={ADSENSE_CLIENT_ID} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {modifiedTime && <meta name="last-modified" content={modifiedTime} />}
    {analyticsConfig.enabled && <script async src={GA4_SCRIPT_SRC}></script>}
    {
      analyticsConfig.enabled && (
        <script
          is:inline
          set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${GA4_MEASUREMENT_ID}');`}
        />
      )
    }
    {monetizationConfig.auto_ads_enabled && <script async src={ADSENSE_SCRIPT_SRC} crossorigin="anonymous"></script>}
    {
      structuredDataList.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body class:list={{ 'page-home': isHomePage }}>
    {
      isHomePage && (
        <div class="site-ambient" aria-hidden="true">
          <span class="site-ambient__orb site-ambient__orb--cyan" />
          <span class="site-ambient__orb site-ambient__orb--violet" />
          <span class="site-ambient__orb site-ambient__orb--indigo" />
        </div>
      )
    }
    <header class="site-header">
      <a class="brand" href="/">Dev Error DB</a>
      <nav aria-label="Primary navigation">
        <a href="/errors/">Errors</a>
        <a href="/#top-categories-heading">Categories</a>
        <a href="/latest/">Latest</a>
        <a href="/trending/">Trending</a>
        <a href="/editorial-methodology/">Methodology</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Static troubleshooting pages for developer errors. Built for fast search, clear fixes, and low-cost hosting.</p>
      <nav aria-label="Footer navigation" class="footer-nav">
        <a href="/about/">About</a>
        <a href="/latest/">Latest</a>
        <a href="/trending/">Trending</a>
        <a href="/contact/">Contact</a>
        <a href="/editorial-methodology/">Editorial Methodology</a>
        <a href="/source-policy/">Source Policy</a>
        <a href="/troubleshooting-methodology/">Troubleshooting Methodology</a>
        <a href="/disclaimer/">Disclaimer</a>
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms/">Terms</a>
      </nav>
    </footer>
  </body>
</html>
